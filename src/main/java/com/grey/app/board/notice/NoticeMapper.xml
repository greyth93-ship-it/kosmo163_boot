<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.grey.app.board.notice.NoticeMapper">
  <!-- File -->
  <insert id="createFile" parameterType="NoticeFileDTO">
  	
  	INSERT INTO TB_NOTICEFILE
  	VALUES (
  		TB_NOTICE_SEQ.NEXTVAL,
  		#{fileName},
  		#{oriName},
  		#{articleNo}
  	)
  </insert>
  
  
  
  <!-- File End -->
  	<sql id="search">
  		WHERE 
  		<choose>
  			<when test="kind == 'v2'">ARTICLE_CONTENT</when>
  			<when test="kind == 'v3'">ARTICLE_WRITER</when>
  			<otherwise>ARTICLE_TITLE</otherwise>
  		</choose>
  		
  		LIKE '%'||#{search}||'%'
  	</sql>
  
  
  	<select id="getCount" resultType="Long" parameterType="Pager">
  		SELECT COUNT(ARTICLE_NO) FROM TB_NOTICE
  		<include refid="search"></include>
  	</select>
  
  	<select id="list" parameterType="Pager" resultType="NoticeDTO">
  		
			SELECT * FROM
				(
					SELECT ROWNUM R, T.* FROM
					(
						SELECT * FROM TB_NOTICE 
						<include refid="search"></include>
						ORDER BY ARTICLE_NO DESC
					) T
				)
			WHERE R BETWEEN #{first} AND #{last}
		
  	</select>
  	
  	<select id="detail" parameterType="NoticeDTO" resultMap="detailResult">
  		SELECT *
		FROM TB_NOTICE n
			LEFT JOIN TB_NOTICEFILE tn 
			USING (ARTICLE_NO)
		WHERE ARTICLE_NO = #{articleNo}
  	</select>
  	<resultMap type="NoticeDTO" id="detailResult">
  		<!-- id ->  PK 입력 -->
  		<id column="ARTICLE_NO" property="articleNo" />
  		<!-- 그 외 나머지 -->
  		<result column="ARTICLE_TITLE" property="articleTitle"/>
  		<result column="ARTICLE_CONTENT" property="articleContent"/>
  		<result column="ARTICLE_HIT" property="articleHit"/>
  		<result column="ARTICLE_DATE" property="articleDate"/>
  		<result column="ARTICLE_WRITER" property="articleWriter"/>
  		
  		<!-- 1:1
  		<association property="" javaType="">
  			<id/>
  			<result/>
  			
  		</association>
  		-->
  		
  		<!-- 1:N -->
  		<collection property="list" javaType="java.util.List" ofType="NoticeFileDTO">
  			<id column="FILE_NO" property="fileNo"/>
  			<result column="FILE_NAME" property="fileName"/>
  			<result column="ORI_NAME" property="oriName"/>
  		</collection>
  	</resultMap>
  	
  	<insert id="create" parameterType="NoticeDTO">
  	
	  	<selectKey order="BEFORE" resultType="Long" keyProperty="articleNo">
	  		SELECT TB_NOTICE_SEQ.NEXTVAL FROM DUAL
	  	</selectKey>
	  	
  		INSERT INTO TB_NOTICE
		VALUES (
			#{articleNo},
			#{articleTitle},
			#{articleContent},
			0,
			sysdate,
			#{articleWriter}
		)
  	</insert>
  	
  	<update id="update" parameterType="NoticeDTO">
  		UPDATE TB_NOTICE
  		SET ARTICLE_TITLE=#{articleTitle}, ARTICLE_CONTENT=#{articleContent}
  		WHERE ARTICLE_NO=#{articleNo}
  	</update>
  	
  	<delete id="delete" parameterType="NoticeDTO">
  		DELETE TB_NOTICE
  		WHERE ARTICLE_NO=#{articleNo}
  	</delete>
  
  
  
  
  </mapper>